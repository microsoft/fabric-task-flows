{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Script Configuration Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "description",
    "task_type_order",
    "category_rotation"
  ],
  "properties": {
    "description": {
      "type": "string"
    },
    "task_type_order": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "description",
        "values"
      ],
      "properties": {
        "description": {
          "type": "string"
        },
        "values": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "category_rotation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "description",
        "values"
      ],
      "properties": {
        "description": {
          "type": "string"
        },
        "values": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
