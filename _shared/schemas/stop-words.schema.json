{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Stop Words Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "description",
    "words"
  ],
  "properties": {
    "description": {
      "type": "string"
    },
    "words": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    }
  }
}
