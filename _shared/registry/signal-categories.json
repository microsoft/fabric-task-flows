{
  "schema": "Fabric Task Flows Signal Categories",
  "version": "2.0.0",
  "description": "v2 schema with weighted keywords, unified signals, canonical examples, exclusions, and category relationships. ⚠️ AGENTS: Do NOT read this file directly — use signal-mapper.py instead.",
  "categories": [
    {
      "id": 1,
      "name": "Real-time / Streaming",
      "velocity": "Real-time",
      "use_case": "Event analytics",
      "task_flow_candidates": [
        "event-analytics",
        "event-medallion"
      ],
      "keywords": {
        "strong": [
          "real-time",
          "streaming",
          "IoT",
          "event hub",
          "CDC",
          "kafka",
          "pub/sub",
          "real time"
        ],
        "moderate": [
          "event-driven",
          "webhooks",
          "telemetry",
          "sensors",
          "low latency",
          "connected devices"
        ],
        "weak": [
          "monitoring",
          "alerts",
          "live",
          "GPS",
          "tracking"
        ]
      },
      "signals": [
        {
          "pattern": "every \\d+ (seconds|minutes|milliseconds)",
          "weight": 3,
          "label": "Temporal frequency"
        },
        {
          "pattern": "\\d+ms latency",
          "weight": 3,
          "label": "Millisecond latency requirement"
        },
        {
          "pattern": "24/7|round-the-clock|always-on",
          "weight": 2,
          "label": "Always-on operations"
        },
        {
          "pattern": "alert[s]? when|notify .{0,20} when|trigger when",
          "weight": 2,
          "label": "Event trigger condition"
        },
        {
          "pattern": "live (view|feed|display|monitor|stream)",
          "weight": 2,
          "label": "Live feed/display"
        },
        {
          "pattern": "\\d+ (events|messages|transactions) per (second|minute)",
          "weight": 3,
          "label": "High-throughput velocity"
        },
        {
          "pattern": "within \\d+ (minutes|seconds)",
          "weight": 2,
          "label": "Latency SLA"
        },
        {
          "pattern": "near.?real.?time",
          "weight": 2,
          "label": "Near-real-time"
        },
        {
          "pattern": "track .{0,15}(fleet|vehicle|shipment|asset|location)",
          "weight": 2,
          "label": "Asset tracking"
        }
      ],
      "examples": [
        "Our IoT sensors send temperature readings every 5 seconds and we need to detect anomalies immediately",
        "We need to track delivery trucks in real-time and alert dispatchers if a vehicle deviates from route",
        "Process credit card transactions and flag suspicious activity within milliseconds"
      ],
      "exclusions": [
        "batch is fine",
        "overnight processing",
        "no real-time needed",
        "daily refresh is enough"
      ],
      "relationships": {
        "combines_with": [
          2
        ],
        "synthesis_produces": 3
      }
    },
