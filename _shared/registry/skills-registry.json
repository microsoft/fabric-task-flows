{
  "$schema": "Fabric Task Flows Skills Registry",
  "$version": "2026-03-13",
  "$description": "Single source of truth for skill metadata. run-pipeline.py reads this for phase routing.",
  "phases": {
    "0a-discovery": {
      "skill": "fabric-discover",
      "output": ["docs/discovery-brief.md"],
      "constraint": "Never decides task flow"
    },
    "1-design": {
      "skill": "fabric-design",
      "output": ["docs/architecture-handoff.md"],
      "constraint": "Never deploys; may compose hybrid architectures"
    },
    "2a-test-plan": {
      "skill": "fabric-test",
      "mode": 1,
      "output": ["docs/test-plan.md"],
      "constraint": "Never invents ACs"
    },
    "2b-sign-off": {
      "skill": null,
      "gate": "human",
      "output": []
    },
    "2c-deploy": {
      "skill": "fabric-deploy",
      "output": ["docs/deployment-handoff.md"],
      "constraint": "Never makes architecture decisions"
    },
    "3-validate": {
      "skill": "fabric-test",
      "mode": 2,
      "output": ["docs/validation-report.md"],
      "constraint": "Never invents ACs"
    },
    "4-document": {
      "skill": "fabric-document",
      "output": ["docs/project-brief.md"],
      "constraint": "Documents only"
    }
  },
  "phase_order": ["0a-discovery", "1-design", "2a-test-plan", "2b-sign-off", "2c-deploy", "3-validate", "4-document"],
  "standalone_skills": {
    "fabric-heal": {
      "constraint": "Never modifies matching algorithm"
    }
  },
  "fallback": {
    "no_phase_match": "Route to fabric-discover for intake. The orchestrator must never answer directly.",
    "out_of_scope": "Decline politely. The agent is a Fabric architecture specialist, not a general-purpose assistant."
  }
}
